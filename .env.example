# Copy to .env and customize as needed.
APP_NAME="AAA - AI Agent Auditor"
DEBUG=false
DATABASE_URL="sqlite:///./aaa.db"
COURTLISTENER_TOKEN=""
VERIFICATION_BASE_URL="https://www.courtlistener.com/api/rest/v4/citation-lookup/"
VERIFICATION_TIMEOUT_SECONDS=8

# ── Outbound email (Resend HTTPS) ─────────────────────────────────────────────
# RESEND_API_KEY is REQUIRED in production. The app refuses to start without
# it. Get a key at https://resend.com/ and verify the sending domain.
RESEND_API_KEY=""

# Address that appears in the From: header on every outbound email.
# Must be on a domain verified in the Resend dashboard.
FINALVERIFY_FROM_EMAIL="john@finalverify.com"

# Admin recipient for contact-form and waitlist signup alerts.
# When unset, those alerts are skipped (logged warning, no error).
NOTIFY_EMAIL=""

# OBSOLETE — was the Gmail App Password under the old smtplib path. No
# longer used. Safe to remove from any .env file you copied previously.
# NOTIFY_EMAIL_APP_PASSWORD=""
