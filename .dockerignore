# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Version control
.git/
.gitignore

# Development / CI tooling
.claude/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Test suite (not needed at runtime)
tests/

# Local database files (image should never bake in data)
*.db
*.db-shm
*.db-wal

# Secrets
.env
*.env

# Node (just in case)
node_modules/

# OS artifacts
.DS_Store
Thumbs.db

# Editor artifacts
.idea/
.vscode/
*.swp
*.swo

# Docker files themselves (no need to copy into the image)
docker-compose*.yml
docker-compose*.yaml
.dockerignore
